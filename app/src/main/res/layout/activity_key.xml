<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp"
        android:paddingTop="80dp"
        android:paddingBottom="48dp">

        <!-- Crosshair logo -->
        <FrameLayout
            android:id="@+id/ivLogo"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginBottom="20dp">

            <!-- Glow ring (outer) -->
            <View
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:background="@drawable/logo_glow_ring"
                android:layout_gravity="center"/>

            <!-- Icon background -->
            <FrameLayout
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:background="@drawable/logo_bg_new">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_logo"/>

            </FrameLayout>

        </FrameLayout>

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="BigHead"
            android:textColor="@color/white"
            android:textSize="34sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Введи ключ активации"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:layout_marginBottom="36dp"/>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardKey"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/panel_bg"
            app:cardCornerRadius="18dp"
            app:cardElevation="8dp"
            app:strokeColor="@color/accent_purple"
            app:strokeWidth="1dp"
            android:layout_marginBottom="10dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="КЛЮЧ ДОСТУПА"
                    android:textColor="@color/accent_cyan"
                    android:textSize="10sp"
                    android:letterSpacing="0.15"
                    android:textStyle="bold"
                    android:layout_marginBottom="10dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="@color/accent_purple"
                    app:hintTextColor="@color/text_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etKey"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="BIGHEAD-XXXX"
                        android:inputType="textVisiblePassword"
                        android:textColor="@color/white"
                        android:textColorHint="@color/text_muted"
                        android:fontFamily="monospace"
                        android:textSize="16sp"
                        android:letterSpacing="0.08"/>

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/error_red"
            android:textSize="13sp"
            android:visibility="invisible"
            android:layout_marginBottom="20dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnActivate"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="АКТИВИРОВАТЬ"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            app:backgroundTint="@color/accent_purple"
            app:cornerRadius="18dp"
            android:layout_marginBottom="14dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTelegram"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🔑  Получить ключ в Telegram"
            android:textSize="13sp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            app:strokeColor="@color/accent_cyan"
            app:strokeWidth="1dp"
            android:textColor="@color/accent_cyan"
            app:cornerRadius="18dp"/>

    </LinearLayout>

</ScrollView>
