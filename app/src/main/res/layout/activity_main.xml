<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark">

    <com.bighead.app.ParticleView
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingHorizontal="32dp">

        <!-- Crosshair logo -->
        <FrameLayout
            android:id="@+id/ivMainLogo"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_marginBottom="24dp">

            <View
                android:layout_width="110dp"
                android:layout_height="110dp"
                android:background="@drawable/logo_glow_ring"
                android:layout_gravity="center"/>

            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:background="@drawable/logo_bg_new">

                <ImageView
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_logo"/>

            </FrameLayout>

        </FrameLayout>

        <TextView
            android:id="@+id/tvMainTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="𝗕𝗜𝗚𝗛𝗘𝗔𝗗"
            android:textColor="@color/white"
            android:textSize="36sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvMainSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="𝗦𝗼𝗳𝘁𝘄𝗮𝗿𝗲 | 𝗡𝗼 𝗥𝗼𝗼𝘁"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginBottom="48dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLaunch"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="𝗜𝗡𝗝𝗘𝗖𝗧"
            android:textSize="15sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            app:backgroundTint="@color/accent_purple"
            app:cornerRadius="18dp"
            android:layout_marginBottom="14dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Сменить ключ"
            android:textSize="13sp"
            android:textColor="@color/text_muted"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            app:cornerRadius="16dp"/>

    </LinearLayout>

</FrameLayout>
